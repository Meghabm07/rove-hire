INTERNAL_API_URL=http://localhost:4000/api
# Used by docker-compose for the web container. Override this in production
# with the private API URL/IP reachable from the web container.
WEB_INTERNAL_API_URL=http://server:4000/api
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use true only when the app is served through HTTPS.
COOKIE_SECURE=false
DATABASE_URL=postgres://rove:rove_password@localhost:5432/rove_hire
POSTGRES_DB=rove_hire
POSTGRES_USER=rove
POSTGRES_PASSWORD=rove_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
